# StockPilot Environment Configuration
# Copy this file to .env and update the values for your environment.

# SECRET_KEY: Used for signing JWT tokens and other cryptographic operations.
# Generate a secure random key for production (e.g., openssl rand -hex 32).
SECRET_KEY=changeme-generate-a-secure-random-key

# ADMIN_USERNAME: Username for the default admin account created on first startup.
ADMIN_USERNAME=admin

# ADMIN_PASSWORD: Password for the default admin account. Change this immediately in production.
ADMIN_PASSWORD=admin

# ADMIN_DISPLAY_NAME: Display name shown in the UI for the default admin account.
ADMIN_DISPLAY_NAME=Administrator

# DATABASE_URL: SQLAlchemy-compatible database connection string.
# For SQLite (default, good for development):
DATABASE_URL=sqlite+aiosqlite:///./stockpilot.db
# For PostgreSQL (recommended for production):
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/stockpilot

# DEBUG: Enable debug mode (True/False). Set to False in production.
DEBUG=True